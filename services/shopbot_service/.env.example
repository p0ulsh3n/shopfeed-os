# ══════════════════════════════════════════════════════════════════
# ShopBot Service — Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp services/shopbot_service/.env.example services/shopbot_service/.env
# ══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
SHOPBOT_ENVIRONMENT=development
SHOPBOT_LOG_LEVEL=DEBUG
SHOPBOT_API_HOST=0.0.0.0
SHOPBOT_API_PORT=8070
SHOPBOT_API_WORKERS=2

# ── Auth ─────────────────────────────────────────────────────────
# REQUIRED — change this to a strong random secret in production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SHOPBOT_INTERNAL_API_KEY=dev-secret-change-me-in-production

# ── vLLM ─────────────────────────────────────────────────────────
SHOPBOT_VLLM_BASE_URL=http://localhost:8000/v1
SHOPBOT_VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct-AWQ
SHOPBOT_VLLM_TIMEOUT=60
SHOPBOT_VLLM_MAX_TOKENS=1024
SHOPBOT_VLLM_TEMPERATURE=0.3
SHOPBOT_VLLM_TOP_P=0.9
SHOPBOT_VLLM_ENABLE_STREAMING=true

# ── Database ─────────────────────────────────────────────────────
SHOPBOT_DATABASE_URL=postgresql+asyncpg://shopbot:shopbot_dev_pass@localhost:5432/shopfeed
POSTGRES_PASSWORD=shopbot_dev_pass

# ── Redis ────────────────────────────────────────────────────────
SHOPBOT_REDIS_URL=redis://localhost:6379/2
SHOPBOT_CACHE_ENABLED=true
SHOPBOT_CACHE_TTL_SECONDS=300

# ── Embeddings ───────────────────────────────────────────────────
SHOPBOT_EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
SHOPBOT_EMBEDDING_DIM=1024
SHOPBOT_EMBEDDING_BATCH_SIZE=64
SHOPBOT_EMBEDDING_DEVICE=cpu
SHOPBOT_EMBEDDING_QUANTIZATION=int8
SHOPBOT_EMBEDDING_RESCORING=true

# ── Search ───────────────────────────────────────────────────────
SHOPBOT_RETRIEVAL_TOP_K_DENSE=50
SHOPBOT_RETRIEVAL_TOP_K_SPARSE=50
SHOPBOT_RETRIEVAL_FINAL_TOP_K=8
SHOPBOT_RRF_K=60
SHOPBOT_MAX_CONTEXT_PRODUCTS=8
SHOPBOT_MAX_HISTORY_TURNS=10

# ── HuggingFace (optional, for gated models) ─────────────────────
# HF_TOKEN=hf_your_token_here
